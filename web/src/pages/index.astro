---
import Layout from '../layouts/Layout.astro';
import ProductGrid from '../components/ProductGrid';
---

<Layout title="みんなの打席">
  <div style="margin-bottom: 10px; text-align: center; padding: 4px 0;">
    <h1 style="font-size: 15px; font-weight: 700; color: var(--accent-primary); margin-bottom: 3px; letter-spacing: 0.08em;">
      みんなの打席
    </h1>
    <p style="font-size: 11px; color: var(--text-secondary);">
      いま打席に立ってる挑戦者たち
    </p>
  </div>

  <ProductGrid client:load infiniteScroll={true} />
</Layout>
